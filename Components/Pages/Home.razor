@page "/"
@rendermode InteractiveServer
@using Calendario.Modelos
@using Calendario.Servicios
@using Calendario.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject CalendarEngine Engine

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Elevation="4" Class="pa-6 rounded-lg"
                Style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
                <MudText Typo="Typo.h5">@DateTime.Now.ToString("dddd, dd MMMM")</MudText>
                <MudDivider Light="true" Class="my-4" />
                <div class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Size="Size.Large" Class="mr-4" />
                    <div>
                        <MudText Typo="Typo.h3">22°C</MudText>
                        <MudText Typo="Typo.subtitle1">Soleado - Madrid</MudText>
                    </div>
                </div>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudText Typo="Typo.h5" Class="mb-4"><b>Eventos para hoy</b></MudText>

            @if (EventosHoy.Any())
            {
                <MudStack Spacing="2">
                    @foreach (var ev in EventosHoy)
                    {
                        <MudAlert Severity="Severity.Normal" Variant="Variant.Filled"
                            Style="@($"background-color: {ev.Color}22; color: #333; border-left: 6px solid {ev.Color}")">
                            <div class="d-flex justify-space-between align-center">
                                <MudText Typo="Typo.body1"><b>@ev.Titulo</b></MudText>
                                <MudText Typo="Typo.body2">@ev.HoraInicio - @ev.HoraFin</MudText>
                            </div>
                        </MudAlert>
                    }
                </MudStack>
            }
            else
            {
                <MudPaper Class="pa-8 d-flex flex-column align-center justify-center" Style="border: 2px dashed #ccc;">
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Default" />
                    <MudText Color="Color.Secondary">No tienes eventos programados para hoy</MudText>
                </MudPaper>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<EventoResumen> EventosHoy = new();

    protected override async Task OnInitializedAsync()
    {
        var calendarios = await DbContext.Calendarios.Include(c => c.Reglas).ThenInclude(r => r.Excepciones).ToListAsync();
        var hoy = DateTime.Today;

        foreach (var cal in calendarios)
        {
            if (cal.Reglas == null) continue;
            foreach (var r in cal.Reglas)
            {
                // Usamos el Engine para ver si hoy toca esta regla
                if (Engine.IsDateInCalendars(hoy.Add(r.HoraInicio), new List<CalendarioDefinition> { cal }))
                {
                    EventosHoy.Add(new EventoResumen
                    {
                        Titulo = r.Titulo,
                        Color = cal.Color ?? "#2196F3",
                        HoraInicio = r.HoraInicio.ToString(@"hh\:mm"),
                        HoraFin = r.HoraFin.ToString(@"hh\:mm")
                    });
                }
            }
        }
    }

    private class EventoResumen
    {
        public string Titulo { get; set; } = "";
        public string Color { get; set; } = "";
        public string HoraInicio { get; set; } = "";
        public string HoraFin { get; set; } = "";
    }
}