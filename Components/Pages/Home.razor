@page "/"
@using Calendario.Servicios
@using Calendario.Modelos

@rendermode InteractiveServer
@inject NavigationManager NavManager
@inject MotorCalendario Engine
@inject ISnackbar Snackbar
@inject RepositorioCalendario Repositorio

<PageTitle>Inicio - Calendario Inteligente</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">

    <MudText Typo="Typo.h3" GutterBottom="true" Color="Color.Primary"><b>Bienvenido</b></MudText>
    <MudText Typo="Typo.subtitle1" Class="mb-8">Gestión inteligente de eventos y predicción meteorológica.</MudText>

    <MudGrid Class="mb-8">

        <MudItem xs="12" md="6">
            <div @onclick="@(() => NavManager.NavigateTo("/clima"))" class="cursor-pointer">
                <MudPaper Elevation="3" Class="pa-6 rounded-lg d-flex align-center hover-card">
                    <MudIcon Icon="@Icons.Material.Filled.WbSunny" Color="Color.Warning" Class="mr-4"
                        Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6"><b>Previsión Meteorológica</b></MudText>
                        <MudText Typo="Typo.body2">Consulta el tiempo para tus eventos</MudText>
                    </div>
                </MudPaper>
            </div>
        </MudItem>

        <MudItem xs="12" md="6">
            <div @onclick="@(() => NavManager.NavigateTo("/calendario-oficial"))" class="cursor-pointer">
                <MudPaper Elevation="3" Class="pa-6 rounded-lg d-flex align-center hover-card">
                    <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" Class="mr-4"
                        Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6"><b>Calendario Completo</b></MudText>
                        <MudText Typo="Typo.body2">Ver vistas mensual, semanal y anual</MudText>
                    </div>
                </MudPaper>
            </div>
        </MudItem>

        <MudItem xs="12" md="12">
            <div @onclick="@(() => NavManager.NavigateTo("/gestion-calendarios"))" class="cursor-pointer">
                <MudPaper Elevation="3" Class="pa-6 rounded-lg d-flex align-center hover-card">
                    <MudIcon Icon="@Icons.Material.Filled.Settings" Color="Color.Secondary" Class="mr-4"
                        Size="Size.Large" />
                    <div>
                        <MudText Typo="Typo.h6"><b>Configuración y Datos</b></MudText>
                        <MudText Typo="Typo.body2">Importar archivos .ICS, crear reglas y gestionar calendarios
                        </MudText>
                    </div>
                </MudPaper>
            </div>
        </MudItem>

    </MudGrid>

    <MudPaper Class="pa-8 mt-4" Elevation="2">
        <MudText Typo="Typo.h5" GutterBottom="true">🔍 Verificador Rápido</MudText>
        <MudText Typo="Typo.body2" Class="mb-4">Busca eventos por fecha y hora específica.</MudText>

        <MudGrid>
            <MudItem xs="12" sm="3">
                <MudDatePicker Label="Selecciona una fecha" @bind-Date="fechaConsulta" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="12" sm="2">
                <MudTextField T="TimeSpan ?" Label="Hora (opcional)" @bind-Value="horaConsulta"
                    InputType="InputType.Time" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect T="int?" Label="Calendario" @bind-Value="calendarioSeleccionadoId" Variant="Variant.Outlined"
                    Clearable="true" AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="int?" Value="null">Todos los calendarios</MudSelectItem>
                    @foreach (var cal in todosLosCalendarios)
                    {
                        <MudSelectItem T="int?" Value="cal.Id">
                            <div class="d-flex align-center gap-2">
                                <div style="width: 12px; height: 12px; border-radius: 50%; background-color: @cal.Color;">
                                </div>
                                @cal.Nombre
                            </div>
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="3" Class="d-flex align-center gap-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="VerificarFecha"
                    StartIcon="@Icons.Material.Filled.Search">
                    Buscar
                </MudButton>
                @if (resultadosBusqueda != null)
                {
                    <MudButton Variant="Variant.Outlined" Color="Color.Default" OnClick="LimpiarBusqueda"
                        StartIcon="@Icons.Material.Filled.Clear">
                        Limpiar
                    </MudButton>
                }
            </MudItem>
        </MudGrid>

        @if (resultadosBusqueda != null)
        {
            <MudDivider Class="my-4" />

            <MudText Typo="Typo.h6" Class="mb-3">
                📅 Resultados para: @fechaConsulta?.ToString("dddd, dd MMMM yyyy")
                @if (horaConsulta.HasValue)
                {
                    <text> a las @horaConsulta.Value.ToString(@"hh\:mm")</text>
                }
            </MudText>

            @if (resultadosBusqueda.Any())
            {
                <MudAlert Severity="Severity.Warning" Class="mb-3">
                    <b>OCUPADO:</b> Se encontraron @resultadosBusqueda.Count evento(s)
                </MudAlert>

                <MudSimpleTable Dense="true" Hover="true" Bordered="true" Style="overflow-x: auto;">
                    <thead>
                        <tr>
                            <th>Calendario</th>
                            <th>Evento</th>
                            <th>Horario</th>
                            <th>Categoría</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var resultado in resultadosBusqueda)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-center gap-2">
                                        <div
                                            style="width: 12px; height: 12px; border-radius: 50%; background-color: @resultado.ColorCalendario;">
                                        </div>
                                        <span>@resultado.NombreCalendario</span>
                                    </div>
                                </td>
                                <td>
                                    <MudText Typo="Typo.body2"><b>@resultado.Titulo</b></MudText>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info">
                                        @resultado.HoraInicio.ToString(@"hh\:mm") - @resultado.HoraFin.ToString(@"hh\:mm")
                                    </MudChip>
                                </td>
                                <td>
                                    <MudChip T="string" Size="Size.Small"
                                        Style="@($"background-color: {resultado.ColorEvento}; color: white;")">
                                        @resultado.Categoria
                                    </MudChip>
                                </td>
                            </tr>
                        }
                    </tbody>
                </MudSimpleTable>
            }
            else
            {
                <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle">
                    <b>DISPONIBLE:</b> No hay eventos programados para este momento.
                </MudAlert>
            }
        }
    </MudPaper>

</MudContainer>

<style>
    .cursor-pointer {
        cursor: pointer;
    }

    .hover-card {
        transition: transform 0.2s, background-color 0.2s;
    }

    .hover-card:hover {
        transform: translateY(-2px);
        background-color: var(--mud-palette-background-grey);
    }
</style>

@code {
    private DateTime? fechaConsulta = DateTime.Today;
    private TimeSpan? horaConsulta = null;
    private List<ResultadoBusqueda>? resultadosBusqueda = null;
    private List<DefinicionCalendario> todosLosCalendarios = new();
    private int? calendarioSeleccionadoId = null;

    protected override async Task OnInitializedAsync()
    {
        todosLosCalendarios = await Repositorio.ObtenerTodosLosCalendarios();
    }

    // Clase para almacenar resultados de búsqueda
    private class ResultadoBusqueda
    {
        public string NombreCalendario { get; set; } = "";
        public string ColorCalendario { get; set; } = "";
        public string Titulo { get; set; } = "";
        public TimeSpan HoraInicio { get; set; }
        public TimeSpan HoraFin { get; set; }
        public string Categoria { get; set; } = "";
        public string ColorEvento { get; set; } = "";
    }

    private async Task VerificarFecha()
    {
        if (!fechaConsulta.HasValue) return;

        resultadosBusqueda = new List<ResultadoBusqueda>();

        // Obtener calendarios (todos o solo el seleccionado)
        var calendarios = todosLosCalendarios;
        if (calendarioSeleccionadoId.HasValue)
        {
            calendarios = todosLosCalendarios.Where(c => c.Id == calendarioSeleccionadoId.Value).ToList();
        }

        // Crear fecha con hora si se especificó
        DateTime fechaBusqueda = fechaConsulta.Value.Date;
        if (horaConsulta.HasValue)
        {
            fechaBusqueda = fechaBusqueda.Add(horaConsulta.Value);
        }

        // Buscar eventos en los calendarios filtrados
        foreach (var cal in calendarios)
        {
            if (cal.Reglas != null)
            {
                foreach (var regla in cal.Reglas)
                {
                    // Si hay hora específica, verificar que el evento esté activo en ese momento
                    bool coincide = false;

                    if (horaConsulta.HasValue)
                    {
                        // Verificar que la fecha coincida y la hora esté dentro del rango
                        if (Engine.VerificarReglaIndividual(fechaBusqueda.Date, regla))
                        {
                            // Verificar que la hora esté dentro del evento
                            if (horaConsulta.Value >= regla.HoraInicio && horaConsulta.Value < regla.HoraFin)
                            {
                                coincide = true;
                            }
                        }
                    }
                    else
                    {
                        // Sin hora específica, buscar todos los eventos del día
                        coincide = Engine.VerificarReglaIndividual(fechaBusqueda, regla);
                    }

                    if (coincide)
                    {
                        resultadosBusqueda.Add(new ResultadoBusqueda
                        {
                            NombreCalendario = cal.Nombre,
                            ColorCalendario = cal.Color,
                            Titulo = regla.Titulo,
                            HoraInicio = regla.HoraInicio,
                            HoraFin = regla.HoraFin,
                            Categoria = regla.Categoria ?? "General",
                            ColorEvento = regla.Color ?? cal.Color
                        });
                    }
                }
            }
        }

        // Ordenar por hora de inicio
        resultadosBusqueda = resultadosBusqueda.OrderBy(r => r.HoraInicio).ToList();
    }

    private void LimpiarBusqueda()
    {
        resultadosBusqueda = null;
        horaConsulta = null;
        calendarioSeleccionadoId = null;
    }
}