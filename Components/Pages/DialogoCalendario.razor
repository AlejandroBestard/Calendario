@using Calendario.Modelos
@inherits MudComponentBase

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Editar Calendario</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Calendario.Nombre" Label="Nombre del Calendario" Variant="Variant.Outlined" Margin="Margin.Dense" />
        <MudColorPicker Label="Color del Calendario" @bind-Text="Calendario.Color" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-4" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public CalendarioDefinition Calendario { get; set; } = new();

    private void Submit() => MudDialog.Close(DialogResult.Ok(Calendario));
    private void Cancel() => MudDialog.Cancel();
}