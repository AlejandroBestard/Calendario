@using Calendario.Modelos
@using Calendario.Servicios
@inherits MudComponentBase

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EventRepeat" Class="mr-3 mb-n1" />
            Nueva Regla de Calendario
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            @* TÍTULO Y CATEGORÍA *@
            <MudItem xs="12" md="7">
                <MudTextField @bind-Value="Regla.Titulo" Label="Nombre del evento/regla" Variant="Variant.Outlined"
                    Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="12" md="5">
                <MudSelect T="string" Label="Categoría" @bind-Value="CategoriaSeleccionada" Variant="Variant.Outlined"
                    Margin="Margin.Dense">
                    <MudSelectItem Value="@("Trabajo")"> Trabajo</MudSelectItem>
                    <MudSelectItem Value="@("Social")"> Social</MudSelectItem>
                    <MudSelectItem Value="@("Cumpleaños")"> Cumpleaños</MudSelectItem>
                    <MudSelectItem Value="@("Deporte")"> Deporte</MudSelectItem>
                    <MudSelectItem Value="@("Personal")"> Personal</MudSelectItem>
                    <MudSelectItem Value="@("Festivo")"> Festivo</MudSelectItem>
                </MudSelect>
            </MudItem>

            @* SELECTOR DE COLOR *@
            <MudItem xs="12">
                <MudColorPicker Label="Color representativo" @bind-Text="ColorHex" Variant="Variant.Outlined"
                    Margin="Margin.Dense" ColorPickerView="ColorPickerView.Palette" />
            </MudItem>

            <MudItem xs="12">
                <MudSelect T="TipoRegla" Label="¿Cómo se repite?" @bind-Value="Regla.Tipo" Variant="Variant.Outlined"
                    Margin="Margin.Dense">
                    <MudSelectItem Value="TipoRegla.Puntual">Una sola vez</MudSelectItem>
                    <MudSelectItem Value="TipoRegla.Semanal">Semanalmente (por días)</MudSelectItem>
                    <MudSelectItem Value="TipoRegla.LunesViernes">De Lunes a Viernes</MudSelectItem>
                    <MudSelectItem Value="TipoRegla.Mensual">Mensualmente (mismo día)</MudSelectItem>
                    <MudSelectItem Value="TipoRegla.Anual">Anualmente (Cumpleaños/Aniversarios)</MudSelectItem>
                    <MudSelectItem Value="TipoRegla.Rango">Rango continuo de fechas</MudSelectItem>
                </MudSelect>
            </MudItem>

            @if (Regla.Tipo == TipoRegla.Semanal)
            {
                <MudItem xs="12">
                    <MudText Typo="Typo.caption" Class="ml-2">Días de la semana:</MudText>
                    <MudStack Row="true" Justify="Justify.Center" Spacing="1">
                        @foreach (var dia in DiasOpciones)
                        {
                            <MudChip T="int" Text="@dia.Value"
                                Variant="@(Regla.DiasSemana.Contains(dia.Key) ? Variant.Filled : Variant.Outlined)"
                                Color="@(Regla.DiasSemana.Contains(dia.Key) ? Color.Primary : Color.Default)"
                                OnClick="@(() => ToggleDia(dia.Key))" />
                        }
                    </MudStack>
                </MudItem>
            }

            @if (Regla.Tipo != TipoRegla.Anual)
            {
                <MudItem xs="6">
                    <MudTextField T="TimeSpan ?" Label="Hora Inicio" @bind-Value="HoraInicioTmp" InputType="InputType.Time"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="6">
                    <MudTextField T="TimeSpan ?" Label="Hora Fin" @bind-Value="HoraFinTmp" InputType="InputType.Time"
                        Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            }

            @* FECHAS *@
            <MudItem xs="6">
                <MudDatePicker Label="Fecha Inicio / Referencia" @bind-Date="FechaInicioTmp" Variant="Variant.Outlined"
                    Margin="Margin.Dense" />
            </MudItem>
            <MudItem xs="6">
                <MudDatePicker Label="Fecha Fin (Vencimiento)" @bind-Date="FechaFinTmp" Variant="Variant.Outlined"
                    Margin="Margin.Dense" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Guardar Regla</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ReglaCalendario Regla { get; set; } = new();

    private string CategoriaSeleccionada = "Personal";
    private string ColorHex = "#2196F3";

    private DateTime? FechaInicioTmp;
    private DateTime? FechaFinTmp;
    private TimeSpan? HoraInicioTmp;
    private TimeSpan? HoraFinTmp;

    private Dictionary<int, string> DiasOpciones = new() {
{ 1, "L" }, { 2, "M" }, { 3, "X" }, { 4, "J" }, { 5, "V" }, { 6, "S" }, { 7, "D" }
};

    protected override void OnInitialized()
    {
        FechaInicioTmp = Regla.FechaInicio;
        FechaFinTmp = Regla.FechaFin;
        HoraInicioTmp = Regla.HoraInicio;
        HoraFinTmp = Regla.HoraFin;

        if (Regla.DiasSemana == null) Regla.DiasSemana = new List<int>();

        // pred per regles noves
        if (Regla.Id == 0)
        {
            FechaInicioTmp = DateTime.Today;
            FechaFinTmp = DateTime.Today.AddYears(5);
        }
    }

    private void ToggleDia(int diaId)
    {
        if (Regla.DiasSemana.Contains(diaId)) Regla.DiasSemana.Remove(diaId);
        else Regla.DiasSemana.Add(diaId);
    }

    private void Submit()
    {
        Regla.FechaInicio = FechaInicioTmp ?? DateTime.Today;
        Regla.FechaFin = FechaFinTmp ?? DateTime.Today;
        Regla.HoraInicio = HoraInicioTmp ?? TimeSpan.Zero;
        Regla.HoraFin = HoraFinTmp ?? TimeSpan.FromHours(1);


        Regla.Titulo = $"[{CategoriaSeleccionada}] {Regla.Titulo}";

        MudDialog.Close(DialogResult.Ok(Regla));
    }

    private void Cancel() => MudDialog.Cancel();
}