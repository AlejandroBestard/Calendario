@using Calendario.Modelos
@using MudBlazor
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.EditCalendar" Class="mr-3 mb-n1" />
            @(Regla.Id == 0 ? "Nueva Regla de Calendario" : "Editar Regla")
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudContainer Style="max-height: 500px; overflow-y: scroll">
            <MudGrid>
                <MudItem xs="12">
                    <MudTextField @bind-Value="Regla.Titulo" Label="Título de la Regla/Evento" Required="true"
                        Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect T="TipoRegla" Label="Tipo de Regla" @bind-Value="Regla.Tipo" Variant="Variant.Outlined">
                        <MudSelectItem Value="TipoRegla.Puntual">Evento Puntual (Un día)</MudSelectItem>
                        <MudSelectItem Value="TipoRegla.Rango">Rango de Fechas (Vacaciones, etc.)</MudSelectItem>
                        <MudSelectItem Value="TipoRegla.Semanal">Recurrencia Semanal (Horario fijo)</MudSelectItem>
                    </MudSelect>
                </MudItem>

                @if (Regla.Tipo == TipoRegla.Semanal)
                {
                    <MudItem xs="12">
                        <MudText Typo="Typo.subtitle2">Días de la semana que aplica:</MudText>
                        <div class="d-flex flex-wrap gap-2 mt-2">
                            @foreach (var dia in DiasOpciones)
                            {
                                <MudCheckBox T="bool" Value="@Regla.DiasSemana.Contains(dia.Key)"
                                    ValueChanged="@((bool val) => ToggleDia(dia.Key, val))" Label="@dia.Value"
                                    Color="Color.Primary" />
                            }
                        </div>
                    </MudItem>
                }

                <MudItem xs="6">
                    <MudDatePicker Label="Fecha Inicio Validez" @bind-Date="FechaInicioBase"
                        Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudDatePicker Label="Fecha Fin Validez" @bind-Date="FechaFinBase" Variant="Variant.Outlined" />
                </MudItem>

                <MudItem xs="6">
                    <MudTimePicker Label="Hora Inicio" @bind-Time="HoraInicioBase" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6">
                    <MudTimePicker Label="Hora Fin" @bind-Time="HoraFinBase" Variant="Variant.Outlined" />
                </MudItem>

                @if (Regla.Id != 0)
                {
                    <MudItem xs="12">
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.button" Color="Color.Secondary">Excepciones (Requisito 3.3)</MudText>
                        <MudList T="string">
                            @foreach (var exc in Regla.Excepciones)
                            {
                                <MudListItem
                                    Icon="@(exc.Tipo == TipoExcepcion.Eliminar ? Icons.Material.Filled.DeleteForever : Icons.Material.Filled.Edit)">
                                    @exc.FechaOriginal.ToShortDateString() - @(exc.Tipo == TipoExcepcion.Eliminar ? "Anulado" :
                                    "Modificado")
                                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                        OnClick="@(() => Regla.Excepciones.Remove(exc))" />
                                </MudListItem>
                            }
                        </MudList>
                    </MudItem>
                }
            </MudGrid>
        </MudContainer>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">Guardar Regla</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public ReglaCalendario Regla { get; set; } = new();

    // Helpers para bindear DateTime? y TimeSpan? de MudBlazor a los tipos de nuestro modelo
    private DateTime? FechaInicioBase { get => Regla.FechaInicio; set => Regla.FechaInicio = value ?? DateTime.Today; }
    private DateTime? FechaFinBase { get => Regla.FechaFin; set => Regla.FechaFin = value ?? DateTime.Today; }
    private TimeSpan? HoraInicioBase { get => Regla.HoraInicio; set => Regla.HoraInicio = value ?? TimeSpan.Zero; }
    private TimeSpan? HoraFinBase { get => Regla.HoraFin; set => Regla.HoraFin = value ?? TimeSpan.Zero; }

    private Dictionary<int, string> DiasOpciones = new()
{
{1, "Lun"}, {2, "Mar"}, {3, "Mie"}, {4, "Jue"}, {5, "Vie"}, {6, "Sab"}, {7, "Dom"}
};

    private void ToggleDia(int diaId, bool value)
    {
        if (value && !Regla.DiasSemana.Contains(diaId)) Regla.DiasSemana.Add(diaId);
        else if (!value) Regla.DiasSemana.Remove(diaId);
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Regla.Titulo))
        {
            Snackbar.Add("El título es obligatorio", Severity.Error);
            return;
        }
        MudDialog.Close(DialogResult.Ok(Regla));
    }

    private void Cancel() => MudDialog.Cancel();
}