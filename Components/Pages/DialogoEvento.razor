@using Calendario.Modelos
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudForm>
            <MudTextField T="string" Label="Título del evento" @bind-Value="ModeloEvento.Titulo" Required="true"
                AutoFocus="true" />

            <MudGrid Class="mt-2">

                <MudItem xs="6">
                    <MudDatePicker Label="Día Inicio" Date="FechaInicio" DateChanged="AlCambiarFechaInicio" />
                </MudItem>

                <MudItem xs="6">
                    <MudTextField T="TimeSpan ?" Label="Hora Inicio" @bind-Value="HoraInicio" InputType="InputType.Time"
                        UserAttributes="@(new Dictionary<string, object> { { "step", "60" } })" />
                </MudItem>

                <MudItem xs="6">
                    <MudDatePicker Label="Día Fin" @bind-Date="FechaFin" />
                </MudItem>

                <MudItem xs="6">
                    <MudTextField T="TimeSpan ?" Label="Hora Fin" @bind-Value="HoraFin" InputType="InputType.Time"
                        UserAttributes="@(new Dictionary<string, object> { { "step", "60" } })" />
                </MudItem>
            </MudGrid>

            <MudText Class="mt-4 mb-2">Selecciona un color:</MudText>
            <MudChipSet T="string" SelectedValue="@ModeloEvento.Color" SelectedValueChanged="ColorSeleccionado"
                CheckMark="true">
                <MudChip T="string" Value="@("#2196F3")" Style="background-color:#2196F3; color:white;">General
                </MudChip>
                <MudChip T="string" Value="@("#4CAF50")" Style="background-color:#4CAF50; color:white;">Personal
                </MudChip>
                <MudChip T="string" Value="@("#F44336")" Style="background-color:#F44336; color:white;">Urgente
                </MudChip>
                <MudChip T="string" Value="@("#FF9800")" Style="background-color:#FF9800; color:white;">Trabajo
                </MudChip>
                <MudChip T="string" Value="@("#9C27B0")" Style="background-color:#9C27B0; color:white;">Ocio</MudChip>
            </MudChipSet>

        </MudForm>
    </DialogContent>
    <DialogActions>
        @if (ModeloEvento.Id > 0)
        {
            <MudButton OnClick="Borrar" Color="Color.Error">Eliminar</MudButton>
        }
        <MudSpacer />
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar">Guardar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public Evento ModeloEvento { get; set; } = new Evento
    {
        Inicio = DateTime.Now,
        Fin =
    DateTime.Now.AddHours(1)
    };

    DateTime? FechaInicio;
    TimeSpan? HoraInicio;
    DateTime? FechaFin;
    TimeSpan? HoraFin;

    protected override void OnInitialized()
    {
        FechaInicio = ModeloEvento.Inicio.Date;
        // Ajustamos para quitar segundos y milisegundos al cargar, queda más limpio
        HoraInicio = new TimeSpan(ModeloEvento.Inicio.Hour, ModeloEvento.Inicio.Minute, 0);

        FechaFin = ModeloEvento.Fin.Date;
        HoraFin = new TimeSpan(ModeloEvento.Fin.Hour, ModeloEvento.Fin.Minute, 0);
    }

    // Sincronización de fechas
    private void AlCambiarFechaInicio(DateTime? nuevaFecha)
    {
        FechaInicio = nuevaFecha;
        if (nuevaFecha.HasValue)
        {
            FechaFin = nuevaFecha.Value;
        }
    }

    void ColorSeleccionado(string color)
    {
        if (!string.IsNullOrEmpty(color))
            ModeloEvento.Color = color;
    }

    private void Cancelar() => MudDialog.Cancel();

    private void Borrar() => MudDialog.Close(DialogResult.Ok("ELIMINAR"));

    private void Guardar()
    {
        ModeloEvento.Inicio = (FechaInicio ?? DateTime.Now.Date) + (HoraInicio ?? TimeSpan.Zero);
        ModeloEvento.Fin = (FechaFin ?? DateTime.Now.Date) + (HoraFin ?? TimeSpan.Zero);
        MudDialog.Close(DialogResult.Ok(ModeloEvento));
    }
}