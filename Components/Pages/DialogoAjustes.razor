@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-3">Configuración del Calendario</MudText>

        <MudSelect T="string" Label="País de Festivos" @bind-Value="PaisSeleccionado" Variant="Variant.Outlined"
            AnchorOrigin="Origin.BottomCenter">
            <MudSelectItem Value="@("ES")">España 🇪🇸</MudSelectItem>
            <MudSelectItem Value="@("US")">Estados Unidos 🇺🇸</MudSelectItem>
            <MudSelectItem Value="@("MX")">México 🇲🇽</MudSelectItem>
            <MudSelectItem Value="@("AR")">Argentina 🇦🇷</MudSelectItem>
            <MudSelectItem Value="@("CO")">Colombia 🇨🇴</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Guardar">Guardar Cambios</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    global::MudBlazor.IMudDialogInstance MudDialog { get; set; } = default!;

    // Recibimos el país que ya estaba seleccionado
    [Parameter] public string PaisSeleccionado { get; set; } = "ES";

    private void Cancelar() => MudDialog.Cancel();

    private void Guardar()
    {
        // Devolvemos el nuevo país seleccionado al calendario principal
        MudDialog.Close(DialogResult.Ok(PaisSeleccionado));
    }
}