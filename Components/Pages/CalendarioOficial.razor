@page "/calendario-oficial"
@rendermode InteractiveServer

@using Calendario.Servicios
@using Calendario.Modelos
@using Calendario.Data
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@inject ApplicationDbContext DbContext
@inject CalendarEngine Engine

<PageTitle>Calendario Oficial</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudGrid Class="align-center">
            <MudItem xs="12" md="4">
                <MudText Typo="Typo.h5" Color="Color.Primary"><b>@ObtenerTituloFecha()</b></MudText>
            </MudItem>

            <MudItem xs="12" md="4" Class="d-flex justify-center">
                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined">
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Dia))" Variant="@(vistaActual == VistaCalendario.Dia ? Variant.Filled : Variant.Outlined)">Día</MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Semana))" Variant="@(vistaActual == VistaCalendario.Semana ? Variant.Filled : Variant.Outlined)">Semana</MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Mes))" Variant="@(vistaActual == VistaCalendario.Mes ? Variant.Filled : Variant.Outlined)">Mes</MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Anio))" Variant="@(vistaActual == VistaCalendario.Anio ? Variant.Filled : Variant.Outlined)">Año</MudButton>
                </MudButtonGroup>
            </MudItem>

            <MudItem xs="12" md="4" Class="d-flex justify-end gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavegarAtras" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" />
                <MudButton OnClick="IrAHoy" Variant="Variant.Outlined">Hoy</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" OnClick="NavegarAdelante" Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="2" Style="min-height: 500px;">
        
        @switch (vistaActual)
        {
            case VistaCalendario.Mes:
                <div class="calendario-grid-mes">
                    @foreach (var dia in diasSemana) { <div class="header-dia">@dia</div> }
                    
                    @foreach (var dia in diasParaMostrar)
                    {
                        <div class="celda-mes @(dia.Month != fechaReferencia.Month ? "fuera-mes" : "")">
                            <div class="numero-dia @(EsHoy(dia) ? "hoy" : "")">@dia.Day</div>
                            <div class="lista-eventos">
                                @foreach (var evento in ObtenerEventos(dia))
                                {
                                    <div class="chip-evento" style="background-color: @(evento.Color ?? "#2196F3")" title="@evento.Titulo">
                                        @evento.Titulo
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                break;

            case VistaCalendario.Semana:
                <div class="calendario-grid-semana">
                    @foreach (var dia in diasParaMostrar)
                    {
                        <div class="columna-semana @(EsHoy(dia) ? "borde-hoy" : "")">
                            <div class="header-semana @(EsHoy(dia) ? "fondo-hoy" : "")">
                                <div class="nombre-dia">@dia.ToString("dddd")</div>
                                <div class="numero-grande">@dia.Day</div>
                            </div>
                            <div class="cuerpo-semana">
                                @foreach (var evento in ObtenerEventos(dia))
                                {
                                    <MudPaper Class="pa-2 mb-2" Elevation="2" Style="@($"border-left: 5px solid {evento.Color ?? "#2196F3"};")">
                                        <MudText Typo="Typo.body2"><b>@evento.Titulo</b></MudText>
                                        <MudText Typo="Typo.caption">@evento.Categoria</MudText>
                                    </MudPaper>
                                }
                            </div>
                        </div>
                    }
                </div>
                break;

            case VistaCalendario.Dia:
                <div class="vista-diaria-container">
                    <MudCard Elevation="0" Outlined="true" Class="pa-4 text-center mb-4">
                        <MudText Typo="Typo.h1" Color="Color.Primary">@fechaReferencia.Day</MudText>
                        <MudText Typo="Typo.h4">@fechaReferencia.ToString("dddd, MMMM yyyy")</MudText>
                    </MudCard>

                    <MudText Typo="Typo.h6" Class="mb-2">Agenda del día:</MudText>
                    @{ var eventosHoy = ObtenerEventos(fechaReferencia); }
                    
                    @if (eventosHoy.Any())
                    {
                        @foreach (var evt in eventosHoy)
                        {
                            <MudAlert Severity="Severity.Normal" Class="mb-2" Style="@($"background-color: {evt.Color}20; border-left: 6px solid {evt.Color};")">
                                <MudText><b>@evt.Titulo</b> (@evt.Categoria)</MudText>
                                <MudText Typo="Typo.caption">Tipo: @evt.Tipo</MudText>
                            </MudAlert>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No hay eventos programados para hoy.</MudAlert>
                    }
                </div>
                break;

            case VistaCalendario.Anio:
                <div class="calendario-grid-anio">
                    @for (int mes = 1; mes <= 12; mes++)
                    {
                        var fechaMes = new DateTime(fechaReferencia.Year, mes, 1);
                        <div class="tarjeta-mes" @onclick="() => IrAMes(mes)">
                            <div class="titulo-mes">@fechaMes.ToString("MMMM").ToUpper()</div>
                            <div class="mini-grid">
                                @{
                                    var diasMini = GenerarDiasMiniMes(fechaMes);
                                    foreach(var d in diasMini)
                                    {
                                        <div class="mini-dia @(TieneEventos(d) ? "con-evento" : "")">@d.Day</div>
                                    }
                                }
                            </div>
                        </div>
                    }
                </div>
                break;
        }
    </MudPaper>
</MudContainer>

<style>
    /* ESTILOS VISTA MES */
    .calendario-grid-mes { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; background: #e0e0e0; border: 1px solid #ddd; }
    .header-dia { background: #f5f5f5; padding: 8px; text-align: center; font-weight: bold; text-transform: uppercase; font-size: 0.8rem; }
    .celda-mes { background: white; min-height: 100px; padding: 4px; display: flex; flex-direction: column; gap: 2px; }
    .fuera-mes { background: #fafafa; color: #ccc; }
    .numero-dia { font-weight: bold; text-align: right; padding-right: 5px; font-size: 0.9rem; }
    .numero-dia.hoy { color: #1976D2; text-decoration: underline; }
    
    /* ESTILOS VISTA SEMANA */
    .calendario-grid-semana { display: grid; grid-template-columns: repeat(7, 1fr); gap: 10px; min-height: 400px; }
    .columna-semana { background: #fdfdfd; border: 1px solid #eee; border-radius: 8px; overflow: hidden; }
    .header-semana { background: #f5f5f5; padding: 10px; text-align: center; border-bottom: 1px solid #eee; }
    .nombre-dia { text-transform: uppercase; font-size: 0.8rem; color: #666; }
    .numero-grande { font-size: 1.5rem; font-weight: bold; color: #333; }
    .cuerpo-semana { padding: 10px; }
    .borde-hoy { border: 2px solid #1976D2; }
    .fondo-hoy { background-color: #E3F2FD; }

    /* ESTILOS VISTA AÑO */
    .calendario-grid-anio { display: grid; grid-template-columns: repeat(4, 1fr); gap: 15px; }
    .tarjeta-mes { border: 1px solid #ddd; padding: 10px; border-radius: 8px; cursor: pointer; transition: 0.2s; }
    .tarjeta-mes:hover { box-shadow: 0 4px 8px rgba(0,0,0,0.1); transform: translateY(-2px); }
    .titulo-mes { text-align: center; font-weight: bold; color: #1976D2; margin-bottom: 5px; font-size: 0.9rem; }
    .mini-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 1px; font-size: 0.6rem; text-align: center; }
    .mini-dia { padding: 1px; color: #666; }
    .mini-dia.con-evento { background-color: #2196F3; color: white; border-radius: 50%; }

    /* GENERICOS */
    .chip-evento { color: white; padding: 2px 5px; border-radius: 4px; font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: pointer; margin-bottom: 1px; }
    @@media (max-width: 960px) {
        .calendario-grid-anio { grid-template-columns: repeat(2, 1fr); }
        .calendario-grid-semana { grid-template-columns: 1fr; } /* En móvil la semana se ve vertical */
    }
</style>

@code {
    // Enum para controlar la máquina de estados de la vista
    public enum VistaCalendario { Dia, Semana, Mes, Anio }
    
    private VistaCalendario vistaActual = VistaCalendario.Mes;
    private DateTime fechaReferencia = DateTime.Today;
    
    private List<CalendarioDefinition> todosLosCalendarios = new();
    private List<DateTime> diasParaMostrar = new(); // Se rellena dinámicamente según la vista
    private string[] diasSemana = { "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom" };

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        ActualizarGrid();
    }

    private async Task CargarDatos()
    {
        todosLosCalendarios = await DbContext.Calendarios
            .Include(c => c.Reglas)
            .AsNoTracking()
            .ToListAsync();
    }

    private void CambiarVista(VistaCalendario nuevaVista)
    {
        vistaActual = nuevaVista;
        ActualizarGrid();
    }

    private void IrAHoy()
    {
        fechaReferencia = DateTime.Today;
        ActualizarGrid();
    }

    // --- LÓGICA DE NAVEGACIÓN INTELIGENTE ---
    private void NavegarAtras()
    {
        fechaReferencia = vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.AddDays(-1),
            VistaCalendario.Semana => fechaReferencia.AddDays(-7),
            VistaCalendario.Mes => fechaReferencia.AddMonths(-1),
            VistaCalendario.Anio => fechaReferencia.AddYears(-1),
            _ => fechaReferencia
        };
        ActualizarGrid();
    }

    private void NavegarAdelante()
    {
        fechaReferencia = vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.AddDays(1),
            VistaCalendario.Semana => fechaReferencia.AddDays(7),
            VistaCalendario.Mes => fechaReferencia.AddMonths(1),
            VistaCalendario.Anio => fechaReferencia.AddYears(1),
            _ => fechaReferencia
        };
        ActualizarGrid();
    }

    // --- GENERACIÓN DE DÍAS SEGÚN VISTA ---
    private void ActualizarGrid()
    {
        diasParaMostrar.Clear();

        if (vistaActual == VistaCalendario.Mes)
        {
            var primerDia = new DateTime(fechaReferencia.Year, fechaReferencia.Month, 1);
            int delta = DayOfWeek.Monday - primerDia.DayOfWeek;
            if (delta > 0) delta -= 7;
            var inicio = primerDia.AddDays(delta);
            for (int i = 0; i < 42; i++) diasParaMostrar.Add(inicio.AddDays(i));
        }
        else if (vistaActual == VistaCalendario.Semana)
        {
            int delta = DayOfWeek.Monday - fechaReferencia.DayOfWeek;
            if (delta > 0) delta -= 7; // Ajuste si es domingo (DayOfWeek 0)
            if (fechaReferencia.DayOfWeek == DayOfWeek.Sunday) delta = -6; // Forzar que la semana empiece en Lunes
            
            var lunes = fechaReferencia.AddDays(fechaReferencia.DayOfWeek == DayOfWeek.Sunday ? -6 : (int)DayOfWeek.Monday - (int)fechaReferencia.DayOfWeek);
            
            // Corrección segura del lunes
            int diff = (7 + (fechaReferencia.DayOfWeek - DayOfWeek.Monday)) % 7;
            var lunesReal = fechaReferencia.AddDays(-1 * diff);

            for (int i = 0; i < 7; i++) diasParaMostrar.Add(lunesReal.AddDays(i));
        }
        // Para Día y Año no necesitamos llenar 'diasParaMostrar' igual
    }

    // --- MÉTODOS AUXILIARES ---
    private string ObtenerTituloFecha()
    {
        return vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.ToLongDateString(),
            VistaCalendario.Semana => $"Semana {ISOWeek.GetWeekOfYear(fechaReferencia)} - {fechaReferencia.Year}",
            VistaCalendario.Mes => fechaReferencia.ToString("MMMM yyyy").ToUpper(),
            VistaCalendario.Anio => fechaReferencia.Year.ToString(),
            _ => ""
        };
    }

    private List<ReglaCalendario> ObtenerEventos(DateTime dia)
    {
        var eventos = new List<ReglaCalendario>();
        foreach (var cal in todosLosCalendarios)
        {
            if (cal.Reglas != null)
            {
                foreach (var r in cal.Reglas)
                {
                    if (Engine.VerificarReglaIndividual(dia, r)) eventos.Add(r);
                }
            }
        }
        return eventos;
    }

    private bool EsHoy(DateTime dia) => dia.Date == DateTime.Today;

    // Helpers para la vista anual
    private void IrAMes(int mes)
    {
        fechaReferencia = new DateTime(fechaReferencia.Year, mes, 1);
        CambiarVista(VistaCalendario.Mes);
    }

    private List<DateTime> GenerarDiasMiniMes(DateTime fechaMes)
    {
        var lista = new List<DateTime>();
        var inicio = new DateTime(fechaMes.Year, fechaMes.Month, 1);
        int dias = DateTime.DaysInMonth(fechaMes.Year, fechaMes.Month);
        for(int i=0; i<dias; i++) lista.Add(inicio.AddDays(i));
        return lista;
    }

    private bool TieneEventos(DateTime dia)
    {
        return ObtenerEventos(dia).Any();
    }
}