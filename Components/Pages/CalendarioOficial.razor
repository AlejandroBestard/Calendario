@page "/calendario-oficial"
@rendermode InteractiveServer

@using Calendario.Servicios
@using Calendario.Modelos
@using Calendario.Data
@using Microsoft.EntityFrameworkCore
@using System.Globalization
@inject AplicacionContextoDB ContextoBD
@inject MotorCalendario Motor
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Calendario Oficial</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">

    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudGrid Class="align-center">

            <MudItem xs="12" md="5">
                <MudText Typo="Typo.caption" Class="mb-1 d-block" Color="Color.Secondary">
                    <b>FILTRAR CALENDARIOS:</b>
                </MudText>

                <div class="d-flex flex-wrap gap-2">
                    <MudChip T="string" Variant="Variant.Outlined" Color="Color.Default" OnClick="ToggleTodos"
                        Size="Size.Small">
                        @(idsCalendariosSeleccionados.Count() == todosLosCalendarios.Count ? "Ocultar Todos" : "Ver            Todos")
                    </MudChip>

                    @foreach (var cal in todosLosCalendarios)
                    {
                        var estaSeleccionado = idsCalendariosSeleccionados.Contains(cal.Id);

                        <MudChip T="int" OnClick="@(() => ToggleCalendario(cal.Id))"
                            Variant="@(estaSeleccionado ? Variant.Filled : Variant.Outlined)"
                            Style="@GetChipStyle(cal, estaSeleccionado)"
                            Icon="@(estaSeleccionado ? Icons.Material.Filled.Check : null)" Size="Size.Small"
                            Class="mud-chip-animation">
                            @cal.Nombre
                        </MudChip>
                    }
                </div>
            </MudItem>

            <MudItem xs="12" md="4" Class="d-flex justify-center flex-column align-center">
                <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-1"><b>@ObtenerTituloFecha()</b></MudText>

                <MudButtonGroup Color="Color.Primary" Variant="Variant.Outlined" Size="Size.Small">
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Dia))"
                        Variant="@(vistaActual == VistaCalendario.Dia ? Variant.Filled : Variant.Outlined)">Día
                    </MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Semana))"
                        Variant="@(vistaActual == VistaCalendario.Semana ? Variant.Filled : Variant.Outlined)">Semana
                    </MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Mes))"
                        Variant="@(vistaActual == VistaCalendario.Mes ? Variant.Filled : Variant.Outlined)">Mes
                    </MudButton>
                    <MudButton OnClick="@(() => CambiarVista(VistaCalendario.Anio))"
                        Variant="@(vistaActual == VistaCalendario.Anio ? Variant.Filled : Variant.Outlined)">Año
                    </MudButton>
                </MudButtonGroup>
            </MudItem>

            <MudItem xs="12" md="3" Class="d-flex justify-end gap-2">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="NavegarAtras" Variant="Variant.Filled"
                    Color="Color.Secondary" Size="Size.Small" />
                <MudButton OnClick="IrAHoy" Variant="Variant.Outlined">Hoy</MudButton>
                <MudIconButton Icon="@Icons.Material.Filled.ArrowForward" OnClick="NavegarAdelante"
                    Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small" />
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4" Elevation="2" Style="min-height: 600px;">

        @switch (vistaActual)
        {
            case VistaCalendario.Mes:
                <div class="calendario-grid-mes">
                    @foreach (var dia in diasSemana)
                    {
                        <div class="header-dia">@dia</div>
                    }

                    @foreach (var dia in diasParaMostrar)
                    {
                        <div
                            class="celda-mes @(dia.Month != fechaReferencia.Month ? "fuera-mes" : "") @(EsDiaPasado(dia) && dia.Month == fechaReferencia.Month ? "dia-pasado" : "")">
                            <div class="numero-dia @(EsHoy(dia) ? "hoy" : "")">@dia.Day</div>
                            <div class="lista-eventos">
                                @foreach (var evento in ObtenerEventos(dia))
                                {
                                    <div class="chip-evento chip-evento-clickable" style="background-color: @evento.Color"
                                        title="@evento.Titulo" @onclick="() => MostrarOpcionesEvento(evento, dia)">
                                        <span style="font-size:0.7em; margin-right:2px;">@evento.HoraInicio.ToString(@"hh\:mm")</span>
                                        @evento.Titulo
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
                break;

            case VistaCalendario.Semana:
                <div class="calendario-grid-semana">
                    @foreach (var dia in diasParaMostrar)
                    {
                        <div class="columna-semana @(EsHoy(dia) ? "borde-hoy" : "") @(EsDiaPasado(dia) ? "dia-pasado" : "")">
                            <div class="header-semana @(EsHoy(dia) ? "fondo-hoy" : "")">
                                <div class="nombre-dia">@dia.ToString("dddd")</div>
                                <div class="numero-grande">@dia.Day</div>
                            </div>
                            <div class="cuerpo-semana">
                                @foreach (var evento in ObtenerEventos(dia))
                                {
                                    <MudPaper Class="pa-2 mb-2 evento-semana" Elevation="2"
                                        Style="@($"border-left: 5px solid {evento.Color}; cursor: pointer;")"
                                        @onclick="() => MostrarOpcionesEvento(evento, dia)">
                                        <div class="d-flex justify-space-between">
                                            <MudText Typo="Typo.caption"><b>@evento.HoraInicio.ToString(@"hh\:mm")</b></MudText>
                                        </div>
                                        <MudText Typo="Typo.body2" Style="line-height:1.2;">@evento.Titulo</MudText>
                                    </MudPaper>
                                }
                            </div>
                        </div>
                    }
                </div>
                break;

            case VistaCalendario.Dia:
                <div class="vista-diaria-container">
                    <MudCard Elevation="0" Outlined="true" Class="pa-4 text-center mb-4">
                        <MudText Typo="Typo.h1" Color="Color.Primary">@fechaReferencia.Day</MudText>
                        <MudText Typo="Typo.h4">@fechaReferencia.ToString("dddd, MMMM yyyy")</MudText>
                    </MudCard>
                    <MudText Typo="Typo.h6" Class="mb-2">Agenda del día:</MudText>
                    @{
                        var eventosHoy = ObtenerEventos(fechaReferencia).OrderBy(e => e.HoraInicio).ToList();
                    }
                    @if (eventosHoy.Any())
                    {
                        @foreach (var evt in eventosHoy)
                        {
                            <MudAlert Severity="Severity.Normal" Class="mb-2"
                                Style="@($"background-color: {evt.Color}20; border-left: 6px solid {evt.Color}; cursor: pointer;")"
                                @onclick="() => MostrarOpcionesEvento(evt, fechaReferencia)">
                                <div class="d-flex gap-4 align-center">
                                    <MudText><b>@evt.HoraInicio.ToString(@"hh\:mm")</b></MudText>
                                    <div>
                                        <MudText><b>@evt.Titulo</b></MudText>
                                        <MudText Typo="Typo.caption">@evt.Categoria</MudText>
                                    </div>
                                </div>
                            </MudAlert>
                        }
                    }
                    else
                    {
                        <MudAlert Severity="Severity.Info">No hay eventos visibles.</MudAlert>
                    }
                </div>
                break;

            case VistaCalendario.Anio:
                <div class="calendario-grid-anio">
                    @for (int mes = 1; mes <= 12; mes++)
                    {
                        var fechaMes = new DateTime(fechaReferencia.Year, mes, 1);
                        <div class="tarjeta-mes" @onclick="() => IrAMes(mes)">
                            <div class="titulo-mes">@fechaMes.ToString("MMMM").ToUpper()</div>
                            <div class="mini-grid">
                                @foreach (var d in GenerarDiasMiniMes(fechaMes))
                                {
                                    <div class="mini-dia @(TieneEventos(d) ? "con-evento" : "") @(EsDiaPasado(d) ? "dia-pasado" : "")">
                                        @d.Day</div>
                                }
                            </div>
                        </div>
                    }
                </div>
                break;
        }
    </MudPaper>
</MudContainer>

<style>
    /* Estilos visuales */
    .mud-chip-animation {
        transition: all 0.3s ease;
    }

    .calendario-grid-mes {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 1px;
        background: #e0e0e0;
        border: 1px solid #ddd;
    }

    .header-dia {
        background: #f5f5f5;
        padding: 8px;
        text-align: center;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.8rem;
    }

    .celda-mes {
        background: white;
        min-height: 120px;
        padding: 4px;
        display: flex;
        flex-direction: column;
        gap: 2px;
        overflow: hidden;
    }

    /* Días de otros meses - solo texto gris, fondo blanco */
    .celda-mes.fuera-mes {
        background: white;
        color: #ccc;
    }

    /* Oscurecer SOLO días que ya pasaron Y son del mes actual */
    .celda-mes.dia-pasado {
        background: #f0f0f0 !important;
    }

    .celda-mes.dia-pasado .numero-dia {
        color: #999;
    }

    .celda-mes.dia-pasado .chip-evento {
        opacity: 0.8;
    }

    /* Vista semana */
    .columna-semana.dia-pasado {
        background: #f8f8f8;
    }

    /* Vista año */
    .mini-dia.dia-pasado {
        opacity: 0.6;
        color: #999;
    }

    .numero-dia {
        font-weight: bold;
        text-align: right;
        padding-right: 5px;
        font-size: 0.9rem;
    }

    .numero-dia.hoy {
        color: #1976D2;
        text-decoration: underline;
    }

    .chip-evento {
        color: white;
        padding: 2px 5px;
        border-radius: 3px;
        font-size: 0.75rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 1px;
        transition: 0.2s;
    }

    .chip-evento-clickable {
        cursor: pointer;
    }

    .chip-evento-clickable:hover {
        opacity: 0.8;
        transform: scale(1.02);
    }

    .calendario-grid-semana {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 10px;
        min-height: 500px;
    }

    .columna-semana {
        background: #fdfdfd;
        border: 1px solid #eee;
        border-radius: 8px;
        overflow: hidden;
    }

    .header-semana {
        background: #f5f5f5;
        padding: 10px;
        text-align: center;
        border-bottom: 1px solid #eee;
    }

    .nombre-dia {
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #666;
    }

    .numero-grande {
        font-size: 1.5rem;
        font-weight: bold;
        color: #333;
    }

    .cuerpo-semana {
        padding: 5px;
    }

    .borde-hoy {
        border: 2px solid #1976D2;
    }

    .fondo-hoy {
        background-color: #E3F2FD;
    }

    .calendario-grid-anio {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
    }

    .tarjeta-mes {
        border: 1px solid #ddd;
        padding: 10px;
        border-radius: 8px;
        cursor: pointer;
        transition: 0.2s;
        background: white;
    }

    .tarjeta-mes:hover {
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        transform: translateY(-2px);
    }

    .titulo-mes {
        text-align: center;
        font-weight: bold;
        color: #1976D2;
        margin-bottom: 5px;
        font-size: 0.9rem;
    }

    .mini-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 1px;
        font-size: 0.6rem;
        text-align: center;
    }

    .mini-dia {
        padding: 2px;
        color: #666;
    }

    .mini-dia.con-evento {
        background-color: #2196F3;
        color: white;
        border-radius: 50%;
        font-weight: bold;
    }

    @@media (max-width: 960px) {
        .calendario-grid-anio {
            grid-template-columns: repeat(2, 1fr);
        }

        .calendario-grid-semana {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    public enum VistaCalendario { Dia, Semana, Mes, Anio }

    // Clase interna para almacenar evento con su color
    private class EventoConColor
    {
        public ReglaCalendario Regla { get; set; } = default!;
        public string Color { get; set; } = "#2196F3";

        public string Titulo => Regla.Titulo;
        public DateTime FechaInicio => Regla.FechaInicio;
        public TimeSpan HoraInicio => Regla.HoraInicio;
        public TimeSpan HoraFin => Regla.HoraFin;
        public string? Categoria => Regla.Categoria;
    }

    private VistaCalendario vistaActual = VistaCalendario.Mes;
    private DateTime fechaReferencia = DateTime.Today;

    private List<DefinicionCalendario> todosLosCalendarios = new();
    private List<DateTime> diasParaMostrar = new();
    private string[] diasSemana = { "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom" };

    // A nes final empleare hashset crec que anira mes rapid https://www.w3schools.com/dsa/dsa_data_hashsets.php
    private HashSet<int> idsCalendariosSeleccionados = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        // Inicialm els seleccionam tots
        idsCalendariosSeleccionados = todosLosCalendarios.Select(c => c.Id).ToHashSet();
        ActualizarGrid();
    }

    private async Task CargarDatos()
    {
        todosLosCalendarios = await ContextoBD.Calendarios
        .Include(c => c.Reglas)
        .ThenInclude(r => r.Excepciones)
        .AsNoTracking()
        .ToListAsync();
    }

    private void ToggleCalendario(int id)
    {
        if (idsCalendariosSeleccionados.Contains(id))
            idsCalendariosSeleccionados.Remove(id);
        else
            idsCalendariosSeleccionados.Add(id);

        StateHasChanged();
    }

    private void ToggleTodos()
    {
        if (idsCalendariosSeleccionados.Count == todosLosCalendarios.Count)
            idsCalendariosSeleccionados.Clear(); // Tots marcar desmarcat
        else
            idsCalendariosSeleccionados = todosLosCalendarios.Select(c => c.Id).ToHashSet(); // Si no, marcam tots

        StateHasChanged();
    }

    // Chips revisar: https://www.telerik.com/blazor-ui/documentation/components/chiplist/overview
    private string GetChipStyle(DefinicionCalendario cal, bool selected)
    {
        // Sino borde color
        if (!selected)
            return $"border-color:{cal.Color}; color:{cal.Color};";

        // Seleccionat fondo blanco
        return $"background-color:{cal.Color}; color:white; border-color:{cal.Color};";
    }

    // Filtro
    private List<EventoConColor> ObtenerEventos(DateTime dia)
    {
        var eventos = new List<EventoConColor>();
        if (idsCalendariosSeleccionados.Count == 0) return eventos;

        foreach (var cal in todosLosCalendarios)
        {
            // Fer que nomes el procesi si esta en el hashset
            if (!idsCalendariosSeleccionados.Contains(cal.Id)) continue;

            if (cal.Reglas != null)
            {
                foreach (var r in cal.Reglas)
                {
                    if (Motor.VerificarReglaIndividual(dia, r))
                    {
                        eventos.Add(new EventoConColor
                        {
                            Regla = r,
                            Color = r.Color ?? cal.Color ?? "#2196F3"
                        });
                    }
                }
            }
        }
        return eventos.OrderBy(e => e.HoraInicio).ToList();
    }

    private void CambiarVista(VistaCalendario v) { vistaActual = v; ActualizarGrid(); }
    private void IrAHoy() { fechaReferencia = DateTime.Today; ActualizarGrid(); }

    private void NavegarAtras()
    {
        fechaReferencia = vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.AddDays(-1),
            VistaCalendario.Semana => fechaReferencia.AddDays(-7),
            VistaCalendario.Mes => fechaReferencia.AddMonths(-1),
            VistaCalendario.Anio => fechaReferencia.AddYears(-1),
            _ => fechaReferencia
        }; ActualizarGrid();
    }

    private void NavegarAdelante()
    {
        fechaReferencia = vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.AddDays(1),
            VistaCalendario.Semana => fechaReferencia.AddDays(7),
            VistaCalendario.Mes => fechaReferencia.AddMonths(1),
            VistaCalendario.Anio => fechaReferencia.AddYears(1),
            _ => fechaReferencia
        }; ActualizarGrid();
    }

    private void ActualizarGrid()
    {
        diasParaMostrar.Clear();
        if (vistaActual == VistaCalendario.Mes)
        {
            var primerDia = new DateTime(fechaReferencia.Year, fechaReferencia.Month, 1);
            int delta = DayOfWeek.Monday - primerDia.DayOfWeek; if (delta > 0) delta -= 7;
            var inicio = primerDia.AddDays(delta);
            for (int i = 0; i < 42; i++) diasParaMostrar.Add(inicio.AddDays(i));
        }
        else if (vistaActual == VistaCalendario.Semana)
        {
            int delta = DayOfWeek.Monday - fechaReferencia.DayOfWeek; if (delta > 0) delta -= 7;
            if (fechaReferencia.DayOfWeek == DayOfWeek.Sunday) delta = -6;
            var diff = (7 + (fechaReferencia.DayOfWeek - DayOfWeek.Monday)) % 7;
            var lunes = fechaReferencia.AddDays(-1 * diff);
            for (int i = 0; i < 7; i++) diasParaMostrar.Add(lunes.AddDays(i));
        }
    }

    private string ObtenerTituloFecha()
    {
        return vistaActual switch
        {
            VistaCalendario.Dia => fechaReferencia.ToLongDateString(),
            VistaCalendario.Semana => $"Semana {ISOWeek.GetWeekOfYear(fechaReferencia)}",
            VistaCalendario.Mes => fechaReferencia.ToString("MMMM yyyy").ToUpper(),
            VistaCalendario.Anio => fechaReferencia.Year.ToString(),
            _ => ""
        };
    }
    private bool EsHoy(DateTime dia) => dia.Date == DateTime.Today;
    private bool EsDiaPasado(DateTime dia) => dia.Date < DateTime.Today;
    private void IrAMes(int mes)
    {
        fechaReferencia = new DateTime(fechaReferencia.Year, mes, 1);
        CambiarVista(VistaCalendario.Mes);
    }
    private List<DateTime> GenerarDiasMiniMes(DateTime fm)
    {
        var l = new List<DateTime>(); var ini = new DateTime(fm.Year, fm.Month, 1);
        int d = DateTime.DaysInMonth(fm.Year, fm.Month); for (int i = 0; i < d; i++) l.Add(ini.AddDays(i)); return l;
    }

    private bool TieneEventos(DateTime d) => ObtenerEventos(d).Any();

    private async Task MostrarOpcionesEvento(EventoConColor evento, DateTime fechaSeleccionada)
    {
        var esRecurrente = evento.Regla.Tipo != TipoRegla.Puntual;

        string mensaje = esRecurrente
        ? $"¿Qué deseas hacer con '{evento.Titulo}' del {fechaSeleccionada:dd/MM/yyyy}?"
        : $"¿Eliminar el evento '{evento.Titulo}'?";

        var parametros = new DialogParameters
        {
            ["Titulo"] = evento.Titulo,
            ["FechaEvento"] = fechaSeleccionada,
            ["EsRecurrente"] = esRecurrente,
            ["Mensaje"] = mensaje
        };

        var opciones = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small };
        var dialogo = await DialogService.ShowAsync<DialogoOpcionesEvento>("Opciones de Evento", parametros, opciones);
        var resultado = await dialogo.Result;

        if (resultado is { Canceled: false, Data: string accion })
        {
            if (accion == "EliminarInstancia")
            {
                await EliminarInstanciaEvento(evento.Regla, fechaSeleccionada);
            }
            else if (accion == "EliminarSerie")
            {
                await EliminarSerieCompleta(evento.Regla.Id);
            }
        }
    }

    private async Task EliminarInstanciaEvento(ReglaCalendario regla, DateTime fecha)
    {
        try
        {
            // Recargar la regla con sus excepciones desde la BD para asegurar el tracking
            var reglaRastreada = await ContextoBD.Reglas
            .Include(r => r.Excepciones)
            .FirstOrDefaultAsync(r => r.Id == regla.Id);

            if (reglaRastreada == null)
            {
                Snackbar.Add("Evento no encontrado", Severity.Warning);
                return;
            }

            // Verificar si ya existe una excepción para esta fecha
            var excepcionExistente = reglaRastreada.Excepciones?
            .FirstOrDefault(e => e.FechaOriginal.Date == fecha.Date);

            if (excepcionExistente != null)
            {
                Snackbar.Add($"Ya existe una excepción para el {fecha:dd/MM/yyyy}", Severity.Warning);
                return;
            }

            // Agregar excepción de tipo Eliminar para esta fecha
            if (reglaRastreada.Excepciones == null)
                reglaRastreada.Excepciones = new List<ExcepcionRegla>();

            var excepcion = new ExcepcionRegla
            {
                ReglaCalendarioId = reglaRastreada.Id,
                FechaOriginal = DateTime.SpecifyKind(fecha.Date, DateTimeKind.Utc),
                Tipo = TipoExcepcion.Eliminar
            };

            reglaRastreada.Excepciones.Add(excepcion);
            await ContextoBD.SaveChangesAsync();

            await CargarDatos();
            Snackbar.Add($"Evento eliminado para el {fecha:dd/MM/yyyy}", Severity.Success);
        }
        catch (Exception ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error: {innerMessage}", Severity.Error);
            Console.WriteLine($"Error completo: {ex}");
        }
    }

    private async Task EliminarSerieCompleta(int reglaId)
    {
        try
        {
            // Recargar la regla desde la BD (las excepciones se eliminarán automáticamente en cascada)
            var regla = await ContextoBD.Reglas
            .FirstOrDefaultAsync(r => r.Id == reglaId);

            if (regla == null)
            {
                Snackbar.Add("Evento no encontrado", Severity.Warning);
                return;
            }

            // Eliminar la regla (las excepciones se eliminarán automáticamente por cascade)
            ContextoBD.Reglas.Remove(regla);
            await ContextoBD.SaveChangesAsync();

            await CargarDatos();
            Snackbar.Add("Serie de eventos eliminada completamente", Severity.Success);
        }
        catch (Exception ex)
        {
            var innerMessage = ex.InnerException?.Message ?? ex.Message;
            Snackbar.Add($"Error: {innerMessage}", Severity.Error);
            Console.WriteLine($"Error completo: {ex}");
        }
    }
}