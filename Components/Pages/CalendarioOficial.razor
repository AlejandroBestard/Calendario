@page "/calendario-oficial"
@rendermode InteractiveServer
@using Calendario.Modelos
@using Calendario.Servicios
@using Calendario.Data
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject CalendarEngine Engine

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-6"><b>Calendario Mensual</b></MudText>

    <div class="calendar-wrapper">
        <div class="calendar-grid">
            @foreach (var d in new[] { "Lun", "Mar", "Mié", "Jue", "Vie", "Sáb", "Dom" })
            {
                <div class="calendar-header">@d</div>
            }

            @{
                var primero = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
                int offset = ((int)primero.DayOfWeek + 6) % 7;
            }

            @for (int i = 0; i < offset; i++)
            {
                <div class="calendar-cell empty"></div>
            }

            @for (int dia = 1; dia <= DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month); dia++)
            {
                var fecha = new DateTime(DateTime.Now.Year, DateTime.Now.Month, dia);
                var eventos = ObtenerEventos(fecha);

                <div class="calendar-cell @(fecha.Date == DateTime.Today ? "today" : "")">
                    <div class="cell-number">@dia</div>
                    @foreach (var ev in eventos)
                    {
                        <div class="event-mini" style="background-color: @(ev.Color)22; border-left: 3px solid @ev.Color">
                            @ev.Titulo
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</MudContainer>

<style>
    .calendar-wrapper {
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        overflow: hidden;
        background: white;
    }

    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
    }

    .calendar-header {
        padding: 10px;
        background: #f5f5f5;
        font-weight: bold;
        text-align: center;
        border-bottom: 1px solid #ddd;
    }

    .calendar-cell {
        min-height: 100px;
        padding: 4px;
        border-right: 1px solid #eee;
        border-bottom: 1px solid #eee;
    }

    .today {
        background-color: #fff9c4;
    }

    .cell-number {
        font-size: 0.8rem;
        font-weight: bold;
        margin-bottom: 4px;
    }

    .event-mini {
        font-size: 0.7rem;
        padding: 2px 4px;
        margin-bottom: 2px;
        border-radius: 2px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
</style>

@code {
    private List<CalendarioDefinition> Calendarios = new();
    protected override async Task OnInitializedAsync() =>
    Calendarios = await DbContext.Calendarios.Include(c => c.Reglas).ThenInclude(r => r.Excepciones).ToListAsync();

    private List<dynamic> ObtenerEventos(DateTime f)
    {
        var res = new List<dynamic>();
        foreach (var cal in Calendarios)
        {
            if (cal.Reglas == null) continue;
            foreach (var r in cal.Reglas)
            {
                if (Engine.IsDateInCalendars(f.Date.Add(r.HoraInicio), new List<CalendarioDefinition> { cal }))
                    res.Add(new { Titulo = r.Titulo, Color = cal.Color ?? "#2196F3" });
            }
        }
        return res;
    }
}