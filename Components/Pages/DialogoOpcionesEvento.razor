@using Calendario.Modelos

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.Event" Class="mr-3 mb-n1" />
            @Titulo
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">@Mensaje</MudText>
        
        @if (EsRecurrente)
        {
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-3">
                Este es un evento recurrente. Selecciona una opción:
            </MudText>
            
            <MudStack Spacing="2">
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Warning" 
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.EventBusy"
                           OnClick="@(() => Confirmar("EliminarInstancia"))">
                    Eliminar solo este evento (@FechaEvento.ToString("dd/MM/yyyy"))
                </MudButton>
                
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Error" 
                           FullWidth="true"
                           StartIcon="@Icons.Material.Filled.DeleteForever"
                           OnClick="@(() => Confirmar("EliminarSerie"))">
                    Eliminar toda la serie de eventos
                </MudButton>
            </MudStack>
        }
        else
        {
            <MudAlert Severity="Severity.Warning" Class="mb-3">
                Esta acción no se puede deshacer.
            </MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        @if (!EsRecurrente)
        {
            <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="@(() => Confirmar("EliminarSerie"))">
                Eliminar
            </MudButton>
        }
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] 
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] 
    public string Titulo { get; set; } = string.Empty;

    [Parameter] 
    public DateTime FechaEvento { get; set; }

    [Parameter] 
    public bool EsRecurrente { get; set; }

    [Parameter] 
    public string Mensaje { get; set; } = string.Empty;

    private void Cancelar() => MudDialog.Cancel();

    private void Confirmar(string accion) => MudDialog.Close(DialogResult.Ok(accion));
}
