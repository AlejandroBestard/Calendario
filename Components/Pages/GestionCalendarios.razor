@page "/gestion-calendarios"
@rendermode InteractiveServer

@using Calendario.Modelos
@using Calendario.Data
@using Calendario.Servicios
@using Microsoft.EntityFrameworkCore
@inject ApplicationDbContext DbContext
@inject ISnackbar Snackbar
@inject CalendarEngine Engine
@inject IDialogService DialogService

<PageTitle>Gestión de Calendarios</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">⚙️ Configuración</MudText>

    <MudPaper Class="pa-4 mb-4 d-flex gap-4 align-center" Elevation="2">
        <MudFileUpload T="IBrowserFile" FilesChanged="ImportarCalendario" Accept=".ics">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.UploadFile">
                    Importar .ICS
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="CrearNuevoCalendario">
            Nuevo Calendario
        </MudButton>
    </MudPaper>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-0" Elevation="2">
                <MudList T="CalendarioDefinition">
                    <MudListSubheader><b>Mis Calendarios</b></MudListSubheader>
                    @if (calendarios.Any())
                    {
                        foreach (var cal in calendarios)
                        {
                            <MudListItem OnClick="@(() => SeleccionarCalendario(cal))" 
                                         Class="@(CalendarioSeleccionado?.Id == cal.Id ? "mud-theme-primary lighten-4" : "")">
                                <div class="d-flex justify-space-between align-center">
                                    <MudText>@cal.Nombre</MudText>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => EliminarCalendario(cal))" />
                                </div>
                            </MudListItem>
                        }
                    }
                    else
                    {
                        <MudListItem><MudText Typo="Typo.body2" Color="Color.Default">No hay calendarios.</MudText></MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (CalendarioSeleccionado != null)
            {
                <MudPaper Class="pa-4" Elevation="2">
                    
                    <MudGrid Class="mb-4 align-center">
                        <MudItem xs="8">
                            <MudTextField @bind-Value="CalendarioSeleccionado.Nombre" Label="Nombre del Calendario" Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="4">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" OnClick="GuardarCambiosCalendario">
                                Actualizar
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                    
                    <MudDivider Class="my-4" />

                    <MudCard Class="mb-4 pa-4" Elevation="0" Outlined="true" Style="background-color: #fafafa;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">➕ Añadir Nuevo Evento</MudText>
                        <MudGrid>
                            <MudItem xs="12" sm="6">
                                <MudTextField @bind-Value="NuevaRegla.Titulo" Label="Título" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>
                            
                            <MudItem xs="12" sm="6">
                                <MudDatePicker Label="Fecha Inicio" @bind-Date="dateStart" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudSelect @bind-Value="NuevaRegla.Categoria" Label="Categoría" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="@("General")">General</MudSelectItem>
                                    <MudSelectItem Value="@("Social")">Social 🥂</MudSelectItem>
                                    <MudSelectItem Value="@("Trabajo")">Trabajo 💼</MudSelectItem>
                                    <MudSelectItem Value="@("Cumpleaños")">Cumpleaños 🎂</MudSelectItem>
                                    <MudSelectItem Value="@("Deportes")">Deportes ⚽</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudColorPicker Label="Color" 
                                                @bind-Text="NuevaRegla.Color" 
                                                Style="width:100%;" 
                                                ShowAlpha="false" 
                                                ColorPickerView="ColorPickerView.Palette" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudSelect @bind-Value="NuevaRegla.Tipo" Label="Repetición" Variant="Variant.Outlined" Margin="Margin.Dense">
                                    <MudSelectItem Value="TipoRegla.Puntual">Una vez</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Semanal">Semanal</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Mensual">Mensual</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Anual">Anual</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" Class="d-flex justify-end">
                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="GuardarRegla" StartIcon="@Icons.Material.Filled.Save">
                                    Guardar Evento
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudCard>

                    <MudTable Items="@CalendarioSeleccionado.Reglas" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Color</MudTh>
                            <MudTh>Evento</MudTh>
                            <MudTh>Tipo</MudTh>
                            <MudTh>Fecha</MudTh>
                            <MudTh>Acción</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudIcon Icon="@Icons.Material.Filled.Circle" Style="@($"color:{context.Color ?? "#9E9E9E"};")" Size="Size.Small" />
                            </MudTd>
                            <MudTd>@context.Titulo</MudTd>
                            <MudTd>@context.Tipo</MudTd>
                            <MudTd>@context.FechaInicio.ToShortDateString()</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="@(() => EliminarRegla(context))" />
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Class="pa-4">No hay eventos. ¡Añade uno arriba!</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </MudPaper>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Selecciona un calendario para empezar.</MudAlert>
            }
        </MudItem>
    </MudGrid>
</MudContainer>

@code {
    private List<CalendarioDefinition> calendarios = new();
    private CalendarioDefinition? CalendarioSeleccionado;
    
    private ReglaCalendario NuevaRegla = new() { Categoria = "General", Color = "#2196F3" };
    private DateTime? dateStart = DateTime.Today;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        calendarios = await DbContext.Calendarios
            .Include(c => c.Reglas)
            .OrderBy(c => c.Id)
            .ToListAsync();
            
        if (CalendarioSeleccionado != null)
        {
            CalendarioSeleccionado = calendarios.FirstOrDefault(c => c.Id == CalendarioSeleccionado.Id);
        }
    }

    private async Task CrearNuevoCalendario()
    {
        try {
            var nuevo = new CalendarioDefinition { Nombre = "Nuevo Calendario", Color = "#2196F3", Reglas = new List<ReglaCalendario>() };
            DbContext.Calendarios.Add(nuevo);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            SeleccionarCalendario(calendarios.Last());
            Snackbar.Add("Calendario creado", Severity.Success);
        } catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private void SeleccionarCalendario(CalendarioDefinition cal)
    {
        CalendarioSeleccionado = cal;
        NuevaRegla = new ReglaCalendario { Categoria = "General", Color = "#2196F3" };
        dateStart = DateTime.Today;
    }

    private async Task GuardarCambiosCalendario()
    {
        if (CalendarioSeleccionado == null) return;
        try {
            DbContext.Calendarios.Update(CalendarioSeleccionado);
            await DbContext.SaveChangesAsync();
            Snackbar.Add("Nombre actualizado", Severity.Success);
        } catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task GuardarRegla()
    {
        if (CalendarioSeleccionado == null || string.IsNullOrWhiteSpace(NuevaRegla.Titulo)) {
            Snackbar.Add("El título es obligatorio", Severity.Warning);
            return;
        }

        try {
            var fechaSegura = DateTime.SpecifyKind(dateStart ?? DateTime.Today, DateTimeKind.Utc);
            NuevaRegla.FechaInicio = fechaSegura;
            NuevaRegla.FechaFin = fechaSegura;
            NuevaRegla.CalendarioId = CalendarioSeleccionado.Id; 
            
            if (string.IsNullOrEmpty(NuevaRegla.Color)) NuevaRegla.Color = "#2196F3";

            if (CalendarioSeleccionado.Reglas == null) CalendarioSeleccionado.Reglas = new List<ReglaCalendario>();
            
            CalendarioSeleccionado.Reglas.Add(NuevaRegla);
            DbContext.Reglas.Add(NuevaRegla);
            await DbContext.SaveChangesAsync();
            
            Snackbar.Add("Evento guardado", Severity.Success);
            
            NuevaRegla = new ReglaCalendario { Categoria = "General", Color = "#2196F3" };
            await CargarDatos();
        } catch (Exception ex) { 
            Snackbar.Add($"Error al guardar: {ex.Message}", Severity.Error); 
        }
    }

    private async Task EliminarCalendario(CalendarioDefinition cal)
    {
        bool? result = await DialogService.ShowMessageBox("Confirmar", "¿Borrar calendario?", yesText:"Borrar", cancelText:"Cancelar");
        if (result == true) {
            DbContext.Calendarios.Remove(cal);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            if (CalendarioSeleccionado == cal) CalendarioSeleccionado = null;
            Snackbar.Add("Eliminado", Severity.Success);
        }
    }

    private async Task EliminarRegla(ReglaCalendario regla)
    {
        DbContext.Reglas.Remove(regla);
        await DbContext.SaveChangesAsync();
        await CargarDatos(); 
        Snackbar.Add("Evento eliminado", Severity.Success);
    }

    private async Task ImportarCalendario(IBrowserFile file)
    {
        if (file == null) return;
        try 
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var reader = new StreamReader(stream);
            var contenido = await reader.ReadToEndAsync();
            var reglasImportadas = Engine.ParsearIcal(contenido);
            
            if (!reglasImportadas.Any()) { Snackbar.Add("Sin eventos", Severity.Warning); return; }

            foreach(var r in reglasImportadas) {
                r.Categoria = "Importado"; 
                r.Color = "#FF9800";
                r.FechaInicio = DateTime.SpecifyKind(r.FechaInicio, DateTimeKind.Utc);
                r.FechaFin = DateTime.SpecifyKind(r.FechaFin, DateTimeKind.Utc);
                if (r.Titulo.Length > 50) r.Titulo = r.Titulo.Substring(0, 50);
            }
            var nuevoCal = new CalendarioDefinition { Nombre = $"Imp: {file.Name}", Color = "#FF9800", Reglas = reglasImportadas };
            DbContext.Calendarios.Add(nuevoCal);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            Snackbar.Add($"Importado correctamente", Severity.Success);
        } catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }
}