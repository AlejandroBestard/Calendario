@page "/gestion-calendarios"
@rendermode InteractiveServer
@using Calendario.Modelos
@using Calendario.Servicios
@using Calendario.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Forms
@inject ApplicationDbContext DbContext
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject CalendarEngine Engine
@inject IJSRuntime JS

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
        <MudText Typo="Typo.h4"><b>Gestión de Calendarios</b></MudText>
        
        <MudStack Row="true">
            @* BOTÓN DE IMPORTACIÓN CORREGIDO (Sin error de label) *@
            <MudFileUpload T="IBrowserFile" FilesChanged="ImportarCalendario" Accept=".ics">
                <ActivatorContent>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.FileUpload">
                        Importar .ics
                    </MudButton>
                </ActivatorContent>
            </MudFileUpload>

            <MudButton Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       StartIcon="@Icons.Material.Filled.Add" 
                       OnClick="CrearNuevoCalendario">
                Nuevo Calendario
            </MudButton>
        </MudStack>
    </MudStack>

    <MudGrid>
        @foreach (var cal in ListaCalendarios)
        {
            <MudItem xs="12" md="6">
                <MudPaper Elevation="4" Class="pa-4" Style="@($"border-left: 8px solid {(cal.Color ?? "#2196F3")};")">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
                        <MudStack Row="true" AlignItems="AlignItems.Center">
                            <MudText Typo="Typo.h6">@cal.Nombre</MudText>
                            <MudTooltip Text="Editar nombre/color">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                                               Size="Size.Small" 
                                               OnClick="@(() => EditarCalendario(cal))" />
                            </MudTooltip>
                        </MudStack>
                        
                        <MudStack Row="true">
                            @* BOTÓN DE EXPORTAR ICAL *@
                            <MudTooltip Text="Descargar .ics">
                                <MudIconButton Icon="@Icons.Material.Filled.FileDownload" 
                                               Color="Color.Info" 
                                               OnClick="@(() => ExportarICal(cal))" />
                            </MudTooltip>
                            <MudTooltip Text="Añadir Regla">
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle" 
                                               Color="Color.Success" 
                                               OnClick="@(() => AgregarRegla(cal))" />
                            </MudTooltip>
                            <MudTooltip Text="Eliminar Calendario">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" 
                                               Color="Color.Error" 
                                               OnClick="@(() => EliminarCalendario(cal))" />
                            </MudTooltip>
                        </MudStack>
                    </MudStack>

                    <MudDivider Class="mb-4" />

                    <MudList T="string" Dense="true">
                        @if (cal.Reglas == null || !cal.Reglas.Any())
                        {
                            <MudListItem>
                                <MudText Typo="Typo.caption">Sin reglas definidas</MudText>
                            </MudListItem>
                        }
                        else
                        {
                            @foreach (var regla in cal.Reglas)
                            {
                                <MudListItem Icon="@ObtenerIcono(regla.Tipo)">
                                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                        <MudText>
                                            <b>@regla.Titulo</b> 
                                            <small>(@regla.HoraInicio.ToString(@"hh\:mm") - @regla.HoraFin.ToString(@"hh\:mm"))</small>
                                        </MudText>
                                        <MudIconButton Icon="@Icons.Material.Filled.Settings" 
                                                       Size="Size.Small" 
                                                       OnClick="@(() => EditarRegla(cal, regla))" />
                                    </MudStack>
                                </MudListItem>
                            }
                        }
                    </MudList>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
</MudContainer>

@code {
    private List<CalendarioDefinition> ListaCalendarios = new();

    protected override async Task OnInitializedAsync() => await CargarDatos();

    private async Task CargarDatos()
    {
        ListaCalendarios = await DbContext.Calendarios
            .Include(c => c.Reglas)
            .ToListAsync();
    }

    private async Task CrearNuevoCalendario()
    {
        var nuevo = new CalendarioDefinition { Nombre = "Nuevo Calendario", Color = "#2196F3" };
        DbContext.Calendarios.Add(nuevo);
        await DbContext.SaveChangesAsync();
        await CargarDatos();
        Snackbar.Add("Calendario creado", Severity.Success);
    }

    // MÉTODO PARA EXPORTAR ARCHIVO .ICS
    private async Task ExportarICal(CalendarioDefinition cal)
    {
        try 
        {
            // 1. Generar el contenido iCal desde el Engine
            var contenidoIcs = Engine.ExportToICal(cal);
            
            // 2. Preparar el nombre del archivo
            var nombreArchivo = $"{cal.Nombre.Replace(" ", "_")}.ics";

            // 3. Llamar a la función JavaScript para descargar el archivo
            await JS.InvokeVoidAsync("descargarArchivo", nombreArchivo, contenidoIcs);
            
            Snackbar.Add($"Exportando '{nombreArchivo}'...", Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al descargar el archivo", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private async Task ImportarCalendario(IBrowserFile file)
    {
        if (file == null) return;
        try 
        {
            using var stream = file.OpenReadStream();
            using var reader = new StreamReader(stream);
            var contenido = await reader.ReadToEndAsync();

            var nuevoCal = new CalendarioDefinition { Nombre = $"Importado: {file.Name}", Color = "#9C27B0" };
            var reglasImportadas = Engine.ParsearIcal(contenido);
            
            foreach(var r in reglasImportadas) {
                nuevoCal.Reglas.Add(r);
            }

            DbContext.Calendarios.Add(nuevoCal);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            Snackbar.Add($"Importación completada: {reglasImportadas.Count} eventos", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Error al importar", Severity.Error);
            Console.WriteLine(ex.Message);
        }
    }

    private async Task EditarCalendario(CalendarioDefinition cal)
    {
        var parametros = new DialogParameters<DialogoCalendario> { { x => x.Calendario, cal } };
        var dialog = await DialogService.ShowAsync<DialogoCalendario>("Editar Calendario", parametros);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            Snackbar.Add("Calendario actualizado", Severity.Info);
        }
    }

    private async Task AgregarRegla(CalendarioDefinition cal)
    {
        var nuevaRegla = new ReglaCalendario { 
            CalendarioId = cal.Id, 
            FechaInicio = DateTime.Today,
            FechaFin = DateTime.Today.AddYears(1),
            DiasSemana = new List<int>() 
        };

        var parametros = new DialogParameters<DialogoRegla> { { x => x.Regla, nuevaRegla } };
        var dialog = await DialogService.ShowAsync<DialogoRegla>("Nueva Regla", parametros);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: ReglaCalendario reglaConfirmada })
        {
            if (cal.Reglas == null) cal.Reglas = new List<ReglaCalendario>();
            cal.Reglas.Add(reglaConfirmada);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
        }
    }

    private async Task EditarRegla(CalendarioDefinition cal, ReglaCalendario regla)
    {
        var parametros = new DialogParameters<DialogoRegla> { { x => x.Regla, regla } };
        var dialog = await DialogService.ShowAsync<DialogoRegla>("Editar Regla", parametros);
        var result = await dialog.Result;

        if (result is { Canceled: false })
        {
            await DbContext.SaveChangesAsync();
            await CargarDatos();
        }
    }

    private async Task EliminarCalendario(CalendarioDefinition cal)
    {
        var confirm = await DialogService.ShowMessageBox("Eliminar", "¿Borrar este calendario?", "Sí", "No");
        if (confirm == true)
        {
            DbContext.Calendarios.Remove(cal);
            await DbContext.SaveChangesAsync();
            await CargarDatos();
            Snackbar.Add("Calendario eliminado", Severity.Warning);
        }
    }

    private string ObtenerIcono(TipoRegla tipo) => tipo switch
    {
        TipoRegla.Semanal => Icons.Material.Filled.Repeat,
        TipoRegla.Mensual => Icons.Material.Filled.CalendarMonth,
        TipoRegla.Anual => Icons.Material.Filled.Cake,
        TipoRegla.Rango => Icons.Material.Filled.DateRange,
        _ => Icons.Material.Filled.Event
    };
}