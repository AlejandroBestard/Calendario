@page "/gestion-calendarios"
@rendermode InteractiveServer

@using Calendario.Modelos
@using Calendario.Servicios
@inject RepositorioCalendario Repositorio
@inject ISnackbar Snackbar
@inject MotorCalendario Motor
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject FestivosService FestivosService

<PageTitle>Gestión de Calendarios</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Configuración</MudText>

    <MudPaper Class="pa-4 mb-4 d-flex gap-4 align-center" Elevation="2">
        <MudFileUpload T="IBrowserFile" FilesChanged="ImportarCalendario" Accept=".ics">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                    StartIcon="@Icons.Material.Filled.UploadFile">
                    Importar .ICS
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" StartIcon="@Icons.Material.Filled.EventNote"
            OnClick="ImportarFestivos">
            Importar Festivos
        </MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
            OnClick="CrearNuevoCalendario">
            Nuevo Calendario
        </MudButton>
    </MudPaper>


    <MudGrid>
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-0" Elevation="2">
                <MudList T="DefinicionCalendario">
                    <MudListSubheader><b>Mis Calendarios</b></MudListSubheader>
                    @if (calendarios.Any())
                    {
                        foreach (var cal in calendarios)
                        {
                            <MudListItem OnClick="@(() => SeleccionarCalendario(cal))"
                                Class="@(CalendarioSeleccionado?.Id == cal.Id ? "mud-theme-primary lighten-4" : "")">
                                <div class="d-flex justify-space-between align-center">
                                    <div class="d-flex align-center gap-2">
                                        <div
                                            style="width: 16px; height: 16px; border-radius: 50%; background-color: @cal.Color; border: 2px solid #fff; box-shadow: 0 0 4px rgba(0,0,0,0.3);">
                                        </div>
                                        <MudText>@cal.Nombre</MudText>
                                    </div>
                                    <div class="d-flex gap-1">
                                        <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                            Color="Color.Info" OnClick="@((e) => ExportarCalendario(cal, e))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                            Color="Color.Error" OnClick="@(() => EliminarCalendario(cal))" />
                                    </div>
                                </div>
                            </MudListItem>
                        }
                    }
                    else
                    {
                        <MudListItem>
                            <MudText Typo="Typo.body2" Color="Color.Default">No hay calendarios.</MudText>
                        </MudListItem>
                    }
                </MudList>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            @if (CalendarioSeleccionado != null)
            {
                <MudPaper Class="pa-4" Elevation="2">

                    <MudGrid Class="mb-4 align-center">
                        <MudItem xs="12" md="6">
                            <MudTextField @bind-Value="CalendarioSeleccionado.Nombre" Label="Nombre del Calendario"
                                Variant="Variant.Outlined" Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudColorPicker @bind-Text="CalendarioSeleccionado.Color" Label="Color del Calendario"
                                Variant="Variant.Outlined" Margin="Margin.Dense" ColorPickerMode="ColorPickerMode.RGB"
                                disablealpha="true" />
                        </MudItem>
                        <MudItem xs="6" md="3">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                OnClick="GuardarCambiosCalendario">
                                Actualizar
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="my-4" />

                    <MudCard Class="mb-4 pa-4" Elevation="0" Outlined="true" Style="background-color: #fafafa;">
                        <MudText Typo="Typo.subtitle2" Class="mb-2">
                            @(NuevaRegla.Id == 0 ? "➕ Añadir Nuevo Evento" : "✏️ Editando Evento")
                        </MudText>

                        <MudGrid>
                            <MudItem xs="12">
                                <MudTextField @bind-Value="NuevaRegla.Titulo" Label="Título del Evento"
                                    Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudDatePicker Label="Fecha" @bind-Date="dateStart" Variant="Variant.Outlined"
                                    Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudTextField T="TimeSpan ?" Label="Hora Inicio" @bind-Value="timeStart"
                                    InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudTextField T="TimeSpan ?" Label="Hora Fin" @bind-Value="timeEnd"
                                    InputType="InputType.Time" Variant="Variant.Outlined" Margin="Margin.Dense" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudSelect @bind-Value="NuevaRegla.Categoria" Label="Categoría" Variant="Variant.Outlined"
                                    Margin="Margin.Dense">
                                    <MudSelectItem Value="@("General")">General</MudSelectItem>
                                    <MudSelectItem Value="@("Social")">Social </MudSelectItem>
                                    <MudSelectItem Value="@("Trabajo")">Trabajo </MudSelectItem>
                                    <MudSelectItem Value="@("Cumpleaños")">Cumpleaños </MudSelectItem>
                                    <MudSelectItem Value="@("Deportes")">Deportes </MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudColorPicker @bind-Text="NuevaRegla.Color" Label="Color del Evento"
                                    Variant="Variant.Outlined" Margin="Margin.Dense" ColorPickerMode="ColorPickerMode.RGB"
                                    disablealpha="true" />
                            </MudItem>

                            <MudItem xs="12" sm="4">
                                <MudSelect @bind-Value="NuevaRegla.Tipo" Label="Repetición" Variant="Variant.Outlined"
                                    Margin="Margin.Dense">
                                    <MudSelectItem Value="TipoRegla.Puntual">Una vez</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.LunesViernes">Lunes a Viernes</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Semanal">Semanal</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Mensual">Mensual</MudSelectItem>
                                    <MudSelectItem Value="TipoRegla.Anual">Anual</MudSelectItem>
                                </MudSelect>
                            </MudItem>

                            <MudItem xs="12" Class="d-flex justify-end gap-2">
                                @if (NuevaRegla.Id != 0)
                                {
                                    <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ResetFormulario">
                                        Cancelar Edición
                                    </MudButton>
                                }

                                <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="GuardarRegla"
                                    StartIcon="@Icons.Material.Filled.Save">
                                    @(NuevaRegla.Id == 0 ? "Crear Evento" : "Guardar Cambios")
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                    </MudCard>

                    <MudTable Items="@CalendarioSeleccionado.Reglas" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Color</MudTh>
                            <MudTh>Evento</MudTh>
                            <MudTh>Horario</MudTh>
                            <MudTh>Tipo</MudTh>
                            <MudTh>Acciones</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudIcon Icon="@Icons.Material.Filled.Circle"
                                    Style="@($"color:{context.Color ?? "#9E9E9E"};")" Size="Size.Small" />
                            </MudTd>
                            <MudTd>
                                <MudText Typo="Typo.body2">@context.Titulo</MudText>
                                <MudText Typo="Typo.caption">@context.Categoria</MudText>
                            </MudTd>
                            <MudTd>
                                @context.FechaInicio.ToString("dd/MM") <br />
                                <b>@context.HoraInicio.ToString(@"hh\:mm") - @context.HoraFin.ToString(@"hh\:mm")</b>
                            </MudTd>
                            <MudTd>@context.Tipo</MudTd>
                            <MudTd>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Primary"
                                    OnClick="@(() => CargarParaEditar(context))" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                    OnClick="@(() => EliminarRegla(context))" />
                            </MudTd>
                        </RowTemplate>
                        <NoRecordsContent>
                            <MudText Class="pa-4">No hay eventos. ¡Añade uno!</MudText>
                        </NoRecordsContent>
                    </MudTable>
                </MudPaper>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Selecciona un calendario para empezar.
                </MudAlert>
            }
        </MudItem>
    </MudGrid>

</MudContainer>

@code {
    private List<DefinicionCalendario> calendarios = new();
    private DefinicionCalendario? CalendarioSeleccionado;

    private ReglaCalendario NuevaRegla = new() { Categoria = "General", Color = "#2196F3" };

    private DateTime? dateStart = DateTime.Today;
    private TimeSpan? timeStart = new TimeSpan(9, 0, 0);
    // Cmbi variable hora fi
    private TimeSpan? timeEnd = new TimeSpan(10, 0, 0);

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        calendarios = await Repositorio.ObtenerTodosLosCalendarios();

        if (CalendarioSeleccionado != null)
        {
            CalendarioSeleccionado = calendarios.FirstOrDefault(c => c.Id == CalendarioSeleccionado.Id);
        }
    }

    private async Task CrearNuevoCalendario()
    {
        try
        {
            var nuevo = new DefinicionCalendario
            {
                Nombre = "Nuevo Calendario",
                Color = "#2196F3",
                Reglas = new List<ReglaCalendario>()
            };
            await Repositorio.AgregarCalendario(nuevo);
            await CargarDatos();
            SeleccionarCalendario(calendarios.Last());
            Snackbar.Add("Calendario creado", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private void SeleccionarCalendario(DefinicionCalendario cal)
    {
        CalendarioSeleccionado = cal;
        ResetFormulario();
    }

    private void ResetFormulario()
    {
        NuevaRegla = new ReglaCalendario { Categoria = "General", Color = "#2196F3" };
        dateStart = DateTime.Today;
        timeStart = new TimeSpan(9, 0, 0);
        timeEnd = new TimeSpan(10, 0, 0); // Reset hora fin
    }

    // Metode per agregar un calendari existent
    private void CargarParaEditar(ReglaCalendario regla)
    {
        NuevaRegla = regla;

        dateStart = regla.FechaInicio.Date;
        timeStart = regla.HoraInicio;
        timeEnd = regla.HoraFin;
    }

    private async Task GuardarCambiosCalendario()
    {
        if (CalendarioSeleccionado == null) return;
        try
        {
            await Repositorio.ActualizarCalendario(CalendarioSeleccionado);
            Snackbar.Add("Nombre actualizado", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task GuardarRegla()
    {
        if (CalendarioSeleccionado == null || string.IsNullOrWhiteSpace(NuevaRegla.Titulo))
        {
            Snackbar.Add("El título es obligatorio", Severity.Warning);
            return;
        }

        try
        {
            // Hora logica inici fi si no posa fi +1 hora (revisar)
            var fechaBase = dateStart ?? DateTime.Today;
            var tInicio = timeStart ?? TimeSpan.Zero;
            var tFin = timeEnd ?? tInicio.Add(TimeSpan.FromHours(1));

            // Validar que Fi sigui mes tard que inici
            if (tFin <= tInicio)
            {
                Snackbar.Add("La hora de fin debe ser posterior a la de inicio", Severity.Warning);
                return;
            }

            // Para eventos recurrentes, FechaInicio es la fecha de inicio y FechaFin es la vigencia (no el mismo día)
            NuevaRegla.FechaInicio = DateTime.SpecifyKind(fechaBase.Date, DateTimeKind.Utc);
            NuevaRegla.HoraInicio = tInicio;
            NuevaRegla.HoraFin = tFin;

            // Para eventos recurrentes (no puntuales), establecer una vigencia larga
            if (NuevaRegla.Tipo != TipoRegla.Puntual)
            {
                // Vigencia de 5 años para eventos recurrentes
                NuevaRegla.FechaFin = DateTime.SpecifyKind(fechaBase.Date.AddYears(5), DateTimeKind.Utc);
            }
            else
            {
                // Para eventos puntuales, FechaFin es el mismo día
                NuevaRegla.FechaFin = DateTime.SpecifyKind(fechaBase.Date, DateTimeKind.Utc);
            }

            NuevaRegla.CalendarioId = CalendarioSeleccionado.Id;
            if (string.IsNullOrEmpty(NuevaRegla.Color)) NuevaRegla.Color = "#2196F3";

            if (CalendarioSeleccionado.Reglas == null) CalendarioSeleccionado.Reglas = new List<ReglaCalendario>();

            if (NuevaRegla.Id == 0)
            {
                await Repositorio.AgregarRegla(CalendarioSeleccionado.Id, NuevaRegla);
                Snackbar.Add("Evento creado", Severity.Success);
            }
            else
            {
                await Repositorio.ActualizarRegla(NuevaRegla);
                Snackbar.Add("Evento actualizado", Severity.Success);
            }

            ResetFormulario();
            await CargarDatos();

        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al guardar: {ex.Message}", Severity.Error);
        }
    }

    private async Task EliminarCalendario(DefinicionCalendario cal)
    {
        bool? result = await DialogService.ShowMessageBox("Confirmar", "¿Borrar calendario?", yesText: "Borrar",
        cancelText: "Cancelar");
        if (result == true)
        {
            await Repositorio.EliminarCalendario(cal.Id);
            await CargarDatos();
            if (CalendarioSeleccionado == cal) CalendarioSeleccionado = null;
            Snackbar.Add("Eliminado", Severity.Success);
        }
    }

    private async Task ExportarCalendario(DefinicionCalendario cal, MouseEventArgs e)
    {
        try
        {
            if (cal.Reglas == null || !cal.Reglas.Any())
            {
                Snackbar.Add("El calendario no tiene eventos", Severity.Warning);
                return;
            }

            var ics = Motor.ExportToICal(cal.Reglas);
            var bytes = System.Text.Encoding.UTF8.GetBytes(ics);

            await JS.InvokeVoidAsync("descargarArchivo", bytes, $"{cal.Nombre}.ics", "text/calendar");
            Snackbar.Add("Calendario exportado", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al exportar: {ex.Message}", Severity.Error);
        }
    }

    private async Task EliminarRegla(ReglaCalendario regla)
    {
        if (NuevaRegla.Id == regla.Id) ResetFormulario();

        await Repositorio.EliminarRegla(regla.Id);
        await CargarDatos();
        Snackbar.Add("Evento eliminado", Severity.Success);
    }

    private async Task ImportarCalendario(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 5);
            using var reader = new StreamReader(stream);
            var contenido = await reader.ReadToEndAsync();
            var reglasImportadas = Motor.ParsearIcal(contenido);

            if (!reglasImportadas.Any()) { Snackbar.Add("Sin eventos", Severity.Warning); return; }

            foreach (var r in reglasImportadas)
            {
                r.Categoria = "Importado";
                r.Color = "#FF9800";
                r.FechaInicio = DateTime.SpecifyKind(r.FechaInicio, DateTimeKind.Utc);
                if (r.FechaFin.HasValue)
                    r.FechaFin = DateTime.SpecifyKind(r.FechaFin.Value, DateTimeKind.Utc);
                else
                    r.FechaFin = DateTime.SpecifyKind(r.FechaInicio, DateTimeKind.Utc);

                if (r.Titulo.Length > 50) r.Titulo = r.Titulo.Substring(0, 50);
            }
            var nuevoCal = new DefinicionCalendario { Nombre = $"Imp: {file.Name}", Color = "#FF9800", Reglas = reglasImportadas };
            await Repositorio.AgregarCalendario(nuevoCal);
            await CargarDatos();
            Snackbar.Add($"Importado correctamente", Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
    }

    private async Task ImportarFestivos()
    {
        try
        {
            var dialogParameters = new DialogParameters<DialogoAjustes>();
            var dialog = await DialogService.ShowAsync<DialogoFestivos>("Importar Festivos", dialogParameters);
            var result = await dialog.Result;

#pragma warning disable CS8602
            if (!result.Canceled && result.Data is (int anio, string codigoPais))
#pragma warning restore CS8602
            {
                Snackbar.Add("Obteniendo festivos...", Severity.Info);

                var festivos = await FestivosService.ObtenerFestivos(anio, codigoPais);

                if (!festivos.Any())
                {
                    Snackbar.Add("No se encontraron festivos", Severity.Warning);
                    return;
                }

                var reglas = festivos.Select(f => new ReglaCalendario
                {
                    Titulo = f.LocalName ?? f.Name,
                    Categoria = "Festivos",
                    Color = "#F44336",
                    Tipo = TipoRegla.Puntual,
                    FechaInicio = DateTime.SpecifyKind(f.Date.AddHours(0), DateTimeKind.Utc),
                    FechaFin = DateTime.SpecifyKind(f.Date.AddHours(23).AddMinutes(59), DateTimeKind.Utc),
                    HoraInicio = TimeSpan.Zero,
                    HoraFin = new TimeSpan(23, 59, 0),
                    DiasSemana = new List<int>()
                }).ToList();

                var nuevoCalendario = new DefinicionCalendario
                {
                    Nombre = $"Festivos {anio} - {codigoPais}",
                    Color = "#F44336",
                    Reglas = reglas
                };

                await Repositorio.AgregarCalendario(nuevoCalendario);
                await CargarDatos();
                Snackbar.Add($"Se importaron {reglas.Count} festivos correctamente", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al importar festivos: {ex.Message}", Severity.Error);
        }
    }
}